<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_overlay_panel"
    android:elevation="8dp"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/headerBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_overlay_header"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/overlay_title"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/buttonEdit"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/action_edit"
            android:padding="5dp"
            android:src="@android:drawable/ic_menu_edit"
            android:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/buttonToggle"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/action_toggle"
            android:padding="5dp"
            android:src="@android:drawable/arrow_up_float"
            android:tint="@android:color/white" />

        <ImageButton
            android:id="@+id/buttonClose"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/action_close"
            android:padding="5dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@android:color/white" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/bodyContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <TextView
                android:id="@+id/textRules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingTop="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="34dp"
                android:textColor="@color/text_primary"
                android:textSize="16sp" />
        </ScrollView>

        <View
            android:id="@+id/resizeHandle"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="bottom|end"
            android:layout_margin="6dp"
            android:background="@drawable/bg_resize_handle" />

    </FrameLayout>

</LinearLayout>
